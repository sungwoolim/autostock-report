# ========================================
# AutoStock Report — 환경변수 설정 예시
# 이 파일을 복사하여 .env 로 저장 후 값을 입력하세요
# cp .env.example .env
# ========================================

# [필수] OpenAI API Key (GPT-4o AI 분석에 사용)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [선택] Google Sheets 서비스 계정 JSON 파일 경로
# Google Cloud Console → IAM → 서비스 계정 → 키 생성
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/your/service_account.json

# [선택] 이메일 발송 (Gmail SMTP)
# Gmail → 계정 보안 → 앱 비밀번호 생성 필요
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# [선택] Reddit API (PRAW) - 더 안정적인 Reddit 수집
# https://www.reddit.com/prefs/apps 에서 앱 등록
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AutoStockBot/1.0
